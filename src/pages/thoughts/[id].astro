---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleJsonLd from "../../components/ArticleJsonLd.astro";
import { getCollection, render } from "astro:content";
import PostNavigation from "../../components/PostNavigation.astro";
import NewsletterSignup from "../../components/NewsletterSignup.astro";
import { SITE_URL, categoryColors } from "../../config";

export async function getStaticPaths() {
  const posts = (
    await getCollection("blog", ({ data }) =>
      import.meta.env.PROD ? data.draft !== true : true
    )
  ).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

  return posts.map((post, index) => ({
    params: { id: post.id },
    props: {
      post,
      prevPost: posts[index + 1] ?? null,
      nextPost: posts[index - 1] ?? null,
    },
  }));
}

const { post, prevPost, nextPost } = Astro.props;
const { Content, remarkPluginFrontmatter } = await render(post);
const minutesRead = remarkPluginFrontmatter.minutesRead;
const colors = categoryColors[post.data.category] || { bg: "#0b1d33", accent: "#4a9eff" };
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <ArticleJsonLd
    slot="head"
    title={post.data.title}
    description={post.data.description}
    publishDate={post.data.date}
    url={`${SITE_URL}/thoughts/${post.id}/`}
    authorName="Dawood Kamar"
  />

  <section
    slot="before-main"
    class="post-hero"
    style={`background-color: ${colors.bg};`}
    transition:name={`post-image-${post.id}`}
  >
    <div class="post-hero-inner">
      <div class="post-hero-meta">
        <span class="font-semibold" style={`color: ${colors.accent};`} transition:name={`post-category-${post.id}`}>
          {post.data.category}
        </span>
        <span class="opacity-30">&mdash;</span>
        <time datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString("en-GB", { dateStyle: "long" })}
        </time>
        <span class="opacity-30">&middot;</span>
        <span>{minutesRead}</span>
      </div>
      <h1 class="post-hero-title" transition:name={`post-title-${post.id}`}>
        {post.data.title}
      </h1>
      <p class="post-hero-description">{post.data.description}</p>
    </div>
  </section>

  <article>
    <div class="prose dark:prose-invert max-w-none">
      <Content />
    </div>
  </article>

  <PostNavigation prevPost={prevPost} nextPost={nextPost} />

  <div class="mt-12">
    <NewsletterSignup />
  </div>
</BaseLayout>
