---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import { categoryColors } from "../../config";

const posts = (
  await getCollection("blog", ({ data }) =>
    import.meta.env.PROD ? data.draft !== true : true
  )
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const postsWithMeta = await Promise.all(
  posts.map(async (post) => {
    const { remarkPluginFrontmatter } = await render(post);
    return { post, minutesRead: remarkPluginFrontmatter.minutesRead };
  })
);
---

<BaseLayout title="Thoughts — Dawood Kamar" description="Writing on AI, focus, and building a meaningful career.">

  <section slot="before-main" class="bg-white dark:bg-black">
    <div class="px-6 pt-24 pb-12 md:pt-32 md:pb-16">
      <h1 class="text-[clamp(3rem,8vw,7rem)] font-bold leading-[0.95] tracking-tighter text-gray-900 dark:text-white">
        Thoughts
      </h1>
    </div>
  </section>

  <section slot="before-main" class="bg-white dark:bg-black">
    <div class="px-6 py-12 md:py-16">
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 lg:gap-8">
        {postsWithMeta.map(({ post, minutesRead }, i) => {
          const colors = categoryColors[post.data.category] || { bg: "#0b1d33", accent: "#4a9eff" };
          return (
            <a
              href={`/thoughts/${post.id}/`}
              class="thoughts-card lg:aspect-[4/5]"
              style={`background-color: ${colors.bg}; animation-delay: ${i * 0.12}s;`}
              transition:name={`post-image-${post.id}`}
            >
              <div class="thoughts-card-inner">
                <div class="thoughts-card-meta">
                  <span class="font-semibold" style={`color: ${colors.accent};`} transition:name={`post-category-${post.id}`}>
                    {post.data.category}
                  </span>
                  <span class="opacity-30">—</span>
                  <time datetime={post.data.date.toISOString()}>
                    {post.data.date.toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" })}
                  </time>
                  <span class="opacity-30">&middot;</span>
                  <span>{minutesRead}</span>
                </div>
                <div class="thoughts-card-content">
                  <h2 class="thoughts-card-title" transition:name={`post-title-${post.id}`}>{post.data.title}</h2>
                  <p class="thoughts-card-description">{post.data.description}</p>
                </div>
              </div>
              <div class="thoughts-card-index" style={`color: ${colors.accent}08;`}>
                {String(i + 1).padStart(2, "0")}
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <script>
    document.addEventListener('astro:after-swap', () => {
      document.querySelectorAll('.thoughts-card').forEach(card => {
        (card as HTMLElement).style.animation = 'none';
        (card as HTMLElement).style.opacity = '1';
      });
    });
  </script>
</BaseLayout>
