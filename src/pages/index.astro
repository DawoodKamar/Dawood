---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import { categoryColors } from "../config";

const allPosts = await getCollection("blog", ({ data }) =>
  import.meta.env.PROD ? data.draft !== true : true
);

const featuredPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const postsWithReadingTime = await Promise.all(
  featuredPosts.map(async (post) => {
    const { remarkPluginFrontmatter } = await render(post);
    return { post, minutesRead: remarkPluginFrontmatter.minutesRead };
  })
);
---

<BaseLayout title="Dawood Kamar" description="Work, AI, and modern life." transparentNav>

  <!-- Section 1: Hero (full-bleed, shares sticky context with nav) -->
  <section slot="hero" class="flex h-screen bg-black text-white overflow-hidden shadow-[0_8px_40px_rgba(0,0,0,0.5)]">
    <!-- Background video -->
    <video
      class="absolute inset-0 h-full w-full object-cover"
      autoplay
      loop
      muted
      playsinline
      preload="auto"
    >
      <source src="/bgvd-compressed.mp4" type="video/mp4" />
    </video>
    <!-- Dark overlay for text readability -->
    <div class="absolute inset-0 z-10 bg-black/15"></div>

    <div class="absolute bottom-12 left-6 z-20 md:bottom-16 md:left-10">
      <p class="hero-tagline mb-4 max-w-xs text-lg font-light tracking-wide text-white sm:max-w-sm sm:text-xl md:ml-4">
        Work, AI, and modern life.
      </p>
      <h1 class="text-[clamp(4.5rem,14vw,13rem)] font-bold leading-[0.9] tracking-tighter">
        <span class="hero-line hero-line-1 block overflow-hidden">
          <span class="hero-line-inner block">Dawood</span>
        </span>
        <span class="hero-line hero-line-2 block overflow-hidden">
          <span class="hero-line-inner block">Kamar</span>
        </span>
      </h1>
    </div>

    <!-- Portrait image -->
    <img
      src="/IMG_8957.PNG"
      alt="Dawood Kamar"
      class="absolute bottom-0 right-0 z-5 h-[70vh] w-auto object-contain"
    />

    <!-- Scroll indicator -->
    <div class="hero-scroll absolute bottom-8 right-6 z-20 lg:left-1/2 lg:right-auto lg:-translate-x-1/2">
      <div class="flex flex-col items-center gap-2 text-white/40">
        <span class="text-[10px] uppercase tracking-[0.3em] text-white">Scroll</span>
        <div class="h-12 w-px bg-linear-to-b from-white/40 to-transparent"></div>
      </div>
    </div>
  </section>

  <!-- Stacking scroll: Featured Posts -->
  {postsWithReadingTime.map(({ post, minutesRead }, i) => {
    const colors = categoryColors[post.data.category] || { bg: "#0b1d33", accent: "#4a9eff" };
    return (
      <div slot="before-main" class="h-[220vh] -mt-[100vh] relative" style={`z-index: ${50 - i * 10};`} data-stack-wrapper>
        <section
          class="stack-section"
          style={`background-color: ${colors.bg};`}
          transition:name={`post-image-${post.id}`}
        >
          {(() => {
            const words = post.data.title.split(/\s+/);
            const wordCount = words.length;
            const descChars = Array.from(post.data.description);
            const descCharCount = descChars.length;
            return (
              <div class="stack-section-inner" style={`--word-count: ${wordCount}; --desc-char-count: ${descCharCount};`}>
                {/* Meta: letter-spacing expands + fades in (typographic settle) */}
                <div class="stack-meta reveal-track-in" style="--reveal-start: 0.3; --reveal-end: 0.5;">
                  <span class="stack-category" style={`color: ${colors.accent};`} transition:name={`post-category-${post.id}`}>{post.data.category}</span>
                  <span class="stack-divider">—</span>
                  <time datetime={post.data.date.toISOString()}>
                    {post.data.date.toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" })}
                  </time>
                  <span class="stack-divider">·</span>
                  <span>{minutesRead}</span>
                </div>
                {/* Title: word-by-word mask rise with blur + scale */}
                <h2 class="stack-title" transition:name={`post-title-${post.id}`}>
                  <a href={`/thoughts/${post.id}/`} aria-label={post.data.title}>
                    {words.map((word, j) => (
                      <span class="stack-title-word" style={`--i: ${j};`} aria-hidden="true">
                        <span class="stack-title-word-inner">{word}</span>
                      </span>
                    ))}
                  </a>
                </h2>
                {/* Description: per-character fade sweep (left → right) */}
                <p class="stack-description reveal-char-sweep" aria-label={post.data.description}>
                  {descChars.map((ch, j) => (
                    <span class="reveal-char" style={`--i: ${j};`} aria-hidden="true">{ch === " " ? " " : ch}</span>
                  ))}
                </p>
                {/* Read link: clip-path wipe + underline grow */}
                <a href={`/thoughts/${post.id}/`} class="stack-read-link reveal-wipe" style={`--accent: ${colors.accent}; --reveal-start: 0.88; --reveal-end: 1;`}>
                  <span class="reveal-wipe-inner">Read</span>
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </a>
              </div>
            );
          })()}
          <div class="stack-index" style={`color: ${colors.accent}08;`}>
            {String(i + 1).padStart(2, "0")}
          </div>
        </section>
      </div>
    );
  })}

  <!-- Footer handles newsletter + closing frame on homepage -->

</BaseLayout>

<script>
  // Scroll-driven reveal progress for each stack section.
  // We publish `--reveal-p` (0 → 1) on each wrapper based on where it sits in
  // the viewport. CSS maps that progress onto each element's animation.
  function initStackReveals() {
    const wrappers = Array.from(
      document.querySelectorAll<HTMLElement>("[data-stack-wrapper]")
    );
    if (!wrappers.length) return;

    let ticking = false;
    const clamp = (v: number) => (v < 0 ? 0 : v > 1 ? 1 : v);

    function update() {
      ticking = false;
      const vh = window.innerHeight;
      for (const wrapper of wrappers) {
        const rect = wrapper.getBoundingClientRect();
        // Reveal over the first 100vh of the wrapper's travel through the
        // viewport — i.e. from when its top meets the viewport top, until
        // the wrapper has scrolled up by one viewport height.
        const scrolled = -rect.top;
        const progress = clamp(scrolled / vh);
        wrapper.style.setProperty("--reveal-p", progress.toFixed(4));
      }
    }

    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(update);
    }

    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll, { passive: true });
    update();

    // Clean up on view-transition navigation away.
    document.addEventListener(
      "astro:before-swap",
      () => {
        window.removeEventListener("scroll", onScroll);
        window.removeEventListener("resize", onScroll);
      },
      { once: true }
    );
  }

  document.addEventListener("astro:page-load", initStackReveals);
</script>
