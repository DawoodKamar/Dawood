---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import NewsletterSignup from "../components/NewsletterSignup.astro";

const allPosts = await getCollection("blog", ({ data }) =>
  import.meta.env.PROD ? data.draft !== true : true
);

const featuredPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const postsWithReadingTime = await Promise.all(
  featuredPosts.map(async (post) => {
    const { remarkPluginFrontmatter } = await render(post);
    return { post, minutesRead: remarkPluginFrontmatter.minutesRead };
  })
);
---

<BaseLayout title="Dawood Kamar" description="AI, work, and modern life.">

  <!-- Section 1: Hero -->
  <section class="py-16 text-center md:py-24">
    <h1 class="text-4xl font-bold tracking-tight md:text-5xl lg:text-6xl">
      Dawood Kamar
    </h1>
    <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-600 dark:text-gray-400 md:text-xl">
      AI, work, and modern life.
    </p>
    <a
      href="/blog/"
      class="mt-8 inline-block rounded-lg bg-blue-600 px-6 py-3 text-sm font-semibold text-white hover:bg-blue-700"
    >
      Read the Blog
    </a>
  </section>

  <!-- Section 2: Positioning -->
  <section class="mx-auto max-w-2xl py-12">
    <h2 class="text-2xl font-bold md:text-3xl">What I Write About</h2>
    <div class="mt-6 space-y-4 text-gray-600 dark:text-gray-400">
      <p>
        I explore how ambitious professionals can use AI as a thinking partner — not a replacement — and why focus is the real competitive advantage in a noisy world.
      </p>
      <p>
        My writing draws from experience across cultures and industries: growing up in South Africa, living in Switzerland, and working at the intersection of technology and business transformation.
      </p>
      <p>
        This is a space for people who want to think clearly, work intentionally, and build something that matters.
      </p>
    </div>
  </section>

  <!-- Section 3: Content Pillars -->
  <section class="py-12">
    <h2 class="text-2xl font-bold md:text-3xl">Content Pillars</h2>
    <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      <div class="rounded-lg border border-gray-200 p-6 dark:border-gray-800">
        <h3 class="font-semibold">AI & Work</h3>
        <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">How to use AI as a thinking partner, cut through the hype, and stay ahead without burning out.</p>
      </div>
      <div class="rounded-lg border border-gray-200 p-6 dark:border-gray-800">
        <h3 class="font-semibold">Focus & Discipline</h3>
        <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Building systems for deep work, managing energy, and making progress on what actually matters.</p>
      </div>
      <div class="rounded-lg border border-gray-200 p-6 dark:border-gray-800">
        <h3 class="font-semibold">Culture & Place</h3>
        <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Lessons from living across continents — how place shapes ambition, perspective, and identity.</p>
      </div>
      <div class="rounded-lg border border-gray-200 p-6 dark:border-gray-800">
        <h3 class="font-semibold">Clarity & Communication</h3>
        <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Writing clearly, thinking precisely, and communicating ideas that move people to action.</p>
      </div>
    </div>
  </section>

  <!-- Section 4: Featured Posts -->
  <section class="py-12">
    <h2 class="text-2xl font-bold md:text-3xl">Latest Writing</h2>
    <div class="mt-8 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {postsWithReadingTime.map(({ post, minutesRead }) => (
        <article class="rounded-lg border border-gray-200 p-6 dark:border-gray-800">
          <div class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400">
            <time datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" })}
            </time>
            <span>·</span>
            <span>{minutesRead}</span>
          </div>
          <h3 class="mt-2 text-lg font-semibold">
            <a href={`/blog/${post.id}/`} class="hover:text-blue-600 dark:hover:text-blue-400">
              {post.data.title}
            </a>
          </h3>
          <p class="mt-2 text-gray-600 dark:text-gray-400">{post.data.description}</p>
          <span class="mt-3 inline-block rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-700 dark:bg-gray-800 dark:text-gray-300">
            {post.data.category}
          </span>
        </article>
      ))}
    </div>
  </section>

  <!-- Section 5: Newsletter -->
  <NewsletterSignup />

</BaseLayout>
