---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

const posts = (
  await getCollection("blog", ({ data }) =>
    import.meta.env.PROD ? data.draft !== true : true
  )
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const postsWithMeta = await Promise.all(
  posts.map(async (post) => {
    const { remarkPluginFrontmatter } = await render(post);
    return { post, minutesRead: remarkPluginFrontmatter.minutesRead };
  })
);
---

<BaseLayout title="Blog — Dawood Kamar" description="Writing on AI, focus, and building a meaningful career.">
  <h1 class="text-3xl font-bold md:text-4xl">Blog</h1>
  <p class="mt-2 text-gray-600 dark:text-gray-400">All posts, newest first.</p>

  <div class="mt-8 grid gap-6">
    {postsWithMeta.map(({ post, minutesRead }) => (
      <article class="rounded-lg border border-gray-200 p-6 dark:border-gray-800">
        <div class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400">
          <time datetime={post.data.date.toISOString()}>
            {post.data.date.toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" })}
          </time>
          <span>·</span>
          <span>{minutesRead}</span>
        </div>
        <h2 class="mt-2 text-xl font-semibold">
          <a href={'/blog/' + post.id + '/'} class="hover:text-blue-600 dark:hover:text-blue-400">
            {post.data.title}
          </a>
        </h2>
        <p class="mt-2 text-gray-600 dark:text-gray-400">{post.data.description}</p>
        <span class="mt-3 inline-block rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-700 dark:bg-gray-800 dark:text-gray-300">
          {post.data.category}
        </span>
      </article>
    ))}
  </div>
</BaseLayout>
