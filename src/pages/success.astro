    <p class="mt-4 text-gray-600 dark:text-gray-400">Thanks for reaching out. I'll get back to you soon.</p>
    <a href="/" class="mt-8 inline-block rounded-lg bg-blue-600 px-6 py-3 text-sm font-semibold text-white hover:bg-blue-700">Back to Home</a>
  </div>

</BaseLayout>
