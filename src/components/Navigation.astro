---
interface Props {
  transparent?: boolean;
}
const { transparent = false } = Astro.props;
const currentPath = Astro.url.pathname;
const navLinks = [
  { href: "/blog/", label: "Thoughts" },
  { href: "/contact/", label: "Reach Me" },
];
---

<header
  class:list={[
    transparent
      ? "absolute top-0 left-0 w-full z-30 text-white"
      : "border-b border-gray-200 dark:border-gray-800",
  ]}
>
  <nav class="flex items-center justify-end px-6 py-4">
    <!-- Desktop nav -->
    <ul class="hidden items-center gap-8 md:flex">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            aria-current={currentPath === link.href ? "page" : undefined}
            class:list={[
              "min-h-[44px] flex items-center text-sm font-medium tracking-wide uppercase",
              transparent
                ? "hover:text-white/70"
                : "hover:text-blue-600 dark:hover:text-blue-400",
              {
                "font-semibold": currentPath === link.href,
                "text-white": transparent && currentPath === link.href,
                "text-blue-600 dark:text-blue-400": !transparent && currentPath === link.href,
              },
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Hamburger button (mobile) -->
    <button
      id="menu-toggle"
      type="button"
      class="md:hidden rounded-lg p-3"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Open navigation menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden" hidden>
    <ul class="space-y-2 px-6 py-4">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            aria-current={currentPath === link.href ? "page" : undefined}
            class:list={[
              "block py-3 text-sm font-medium tracking-wide uppercase",
              transparent
                ? "hover:text-white/70"
                : "hover:text-blue-600 dark:hover:text-blue-400",
              {
                "font-semibold": currentPath === link.href,
              },
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  document.addEventListener("astro:page-load", () => {
    const menuToggle = document.getElementById("menu-toggle");
    const mobileMenu = document.getElementById("mobile-menu");

    if (menuToggle && mobileMenu) {
      menuToggle.addEventListener("click", () => {
        const expanded = menuToggle.getAttribute("aria-expanded") === "true";
        menuToggle.setAttribute("aria-expanded", String(!expanded));
        mobileMenu.hidden = expanded;
      });
    }
  });
</script>
