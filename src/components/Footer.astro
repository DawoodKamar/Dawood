---
import NewsletterSignup from "./NewsletterSignup.astro";
const isHome = Astro.url.pathname === "/";
const isBlogPost = Astro.url.pathname.startsWith("/blog/") && Astro.url.pathname !== "/blog/";
---

{!isHome && !isBlogPost && <div class="mx-auto max-w-4xl px-4 pt-8"><NewsletterSignup compact /></div>}
<footer class:list={[
  isHome && "relative min-h-screen flex flex-col justify-between bg-white dark:bg-black text-gray-900 dark:text-white overflow-hidden",
  !isHome && "border-t border-gray-200 dark:border-gray-800"
]}>
  {isHome && (
    <>
      <!-- WebGL flowing noise canvas -->
      <canvas id="footer-webgl" class="absolute inset-0 w-full h-full z-0"></canvas>

      <!-- Large name top-left -->
      <div class="relative z-10 flex-1 flex items-end px-6 pb-16 md:px-10">
        <h2 class="text-[clamp(4.5rem,14vw,13rem)] font-bold leading-[0.9] tracking-tighter">
          <span class="block">Dawood</span>
          <span class="block">Kamar</span>
        </h2>
      </div>
    </>
  )}

  <!-- Bottom bar -->
  <div class:list={[
    "relative z-10 w-full border-t",
    isHome
      ? "border-gray-300/30 dark:border-white/10 px-6 py-4 md:px-10"
      : "border-gray-200 dark:border-gray-800 px-6 py-8"
  ]}>
    <div class:list={[
      "flex flex-col gap-4 md:flex-row md:items-center md:justify-between",
      !isHome && "mx-auto max-w-4xl"
    ]}>
      <p class:list={[
        "text-sm",
        isHome ? "text-gray-500 dark:text-white/40" : "text-gray-500 dark:text-gray-400"
      ]}>
        &copy; {new Date().getFullYear()} Dawood Kamar
      </p>

      <nav class="flex gap-6 text-sm">
        <a href="/" class:list={[
          "py-2 inline-flex items-center font-medium tracking-wide uppercase transition-colors",
          isHome ? "text-gray-600 hover:text-gray-900 dark:text-white/60 dark:hover:text-white" : "hover:text-blue-600 dark:hover:text-blue-400"
        ]}>Home</a>
        <a href="/blog/" class:list={[
          "py-2 inline-flex items-center font-medium tracking-wide uppercase transition-colors",
          isHome ? "text-gray-600 hover:text-gray-900 dark:text-white/60 dark:hover:text-white" : "hover:text-blue-600 dark:hover:text-blue-400"
        ]}>Thoughts</a>
        <a href="/contact/" class:list={[
          "py-2 inline-flex items-center font-medium tracking-wide uppercase transition-colors",
          isHome ? "text-gray-600 hover:text-gray-900 dark:text-white/60 dark:hover:text-white" : "hover:text-blue-600 dark:hover:text-blue-400"
        ]}>Contact</a>
      </nav>

      <div class="flex items-center gap-4">
        <a
          href="https://youtube.com/@dawoodkamar"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="YouTube"
          class:list={[
            "py-2 inline-flex items-center text-sm transition-colors",
            isHome ? "text-gray-500 hover:text-gray-900 dark:text-white/40 dark:hover:text-white" : "text-gray-500 hover:text-blue-600 dark:text-gray-400 dark:hover:text-blue-400"
          ]}
        >YouTube</a>
        <a
          href="https://linkedin.com/in/dawood-kamar"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class:list={[
            "py-2 inline-flex items-center text-sm transition-colors",
            isHome ? "text-gray-500 hover:text-gray-900 dark:text-white/40 dark:hover:text-white" : "text-gray-500 hover:text-blue-600 dark:text-gray-400 dark:hover:text-blue-400"
          ]}
        >LinkedIn</a>
        <span class:list={[isHome ? "text-gray-300 dark:text-white/10" : "text-gray-300 dark:text-gray-700"]}>|</span>
        <button
          id="theme-toggle"
          type="button"
          class:list={[
            "py-2 text-xs tracking-wide uppercase transition-colors",
            isHome ? "text-gray-400 hover:text-gray-700 dark:text-white/30 dark:hover:text-white/60" : "text-gray-400 hover:text-gray-600 dark:text-gray-500 dark:hover:text-gray-300"
          ]}
          aria-label="Toggle theme"
        ></button>
      </div>
    </div>
  </div>
</footer>

<script>
  document.addEventListener("astro:page-load", () => {
    const btn = document.getElementById("theme-toggle");
    if (!btn) return;

    const isDark = () => document.documentElement.classList.contains("dark");
    btn.textContent = isDark() ? "Light" : "Dark";

    btn.addEventListener("click", () => {
      document.documentElement.classList.toggle("dark");
      const dark = isDark();
      localStorage.setItem("theme", dark ? "dark" : "light");
      btn.textContent = dark ? "Light" : "Dark";
    });
  });
</script>

<!-- WebGL domain-warped noise field -->
<script>
  document.addEventListener("astro:page-load", () => {
    const canvas = document.getElementById("footer-webgl") as HTMLCanvasElement;
    if (!canvas) return;

    const gl = canvas.getContext("webgl");
    if (!gl) return;

    // ── Shaders ──

    const vertSrc = `
      attribute vec2 a_position;
      void main() {
        gl_Position = vec4(a_position, 0.0, 1.0);
      }
    `;

    const fragSrc = `
      precision highp float;

      uniform vec2 u_resolution;
      uniform float u_time;
      uniform vec2 u_mouse;
      uniform float u_dark;

      /* ── Simplex 2-D noise (Ashima / webgl-noise) ── */
      vec3 mod289(vec3 x) { return x - floor(x * (1.0/289.0)) * 289.0; }
      vec2 mod289(vec2 x) { return x - floor(x * (1.0/289.0)) * 289.0; }
      vec3 permute(vec3 x) { return mod289(((x * 34.0) + 10.0) * x); }

      float snoise(vec2 v) {
        const vec4 C = vec4(
          0.211324865405187,   // (3-sqrt(3))/6
          0.366025403784439,   //  0.5*(sqrt(3)-1)
         -0.577350269189626,   // -1 + 2*C.x
          0.024390243902439    //  1/41
        );
        vec2 i  = floor(v + dot(v, C.yy));
        vec2 x0 = v - i + dot(i, C.xx);
        vec2 i1 = (x0.x > x0.y) ? vec2(1.0, 0.0) : vec2(0.0, 1.0);
        vec4 x12 = x0.xyxy + C.xxzz;
        x12.xy -= i1;
        i = mod289(i);
        vec3 p = permute(
          permute(i.y + vec3(0.0, i1.y, 1.0))
                + i.x + vec3(0.0, i1.x, 1.0)
        );
        vec3 m = max(0.5 - vec3(
          dot(x0, x0),
          dot(x12.xy, x12.xy),
          dot(x12.zw, x12.zw)
        ), 0.0);
        m = m * m;
        m = m * m;
        vec3 x_ = 2.0 * fract(p * C.www) - 1.0;
        vec3 h  = abs(x_) - 0.5;
        vec3 ox = floor(x_ + 0.5);
        vec3 a0 = x_ - ox;
        m *= 1.79284291400159 - 0.85373472095314 * (a0*a0 + h*h);
        vec3 g;
        g.x  = a0.x * x0.x  + h.x * x0.y;
        g.yz = a0.yz * x12.xz + h.yz * x12.yw;
        return 130.0 * dot(m, g);
      }

      /* ── Fractal Brownian Motion ── */
      float fbm(vec2 p) {
        float v = 0.0, a = 0.5;
        mat2 rot = mat2(0.8, 0.6, -0.6, 0.8);   // rotation between octaves
        for (int i = 0; i < 4; i++) {
          v += a * snoise(p);
          p = rot * p * 2.0;
          a *= 0.5;
        }
        return v;
      }

      void main() {
        vec2 uv = gl_FragCoord.xy / u_resolution;
        float aspect = u_resolution.x / u_resolution.y;
        vec2 p = vec2(uv.x * aspect, uv.y) * 2.5;

        // ── Mouse warp ──
        vec2 mUV = u_mouse / u_resolution;
        mUV.x *= aspect;
        mUV *= 2.5;
        float mDist = length(p - mUV);
        float mInf  = smoothstep(1.2, 0.0, mDist);

        // ── Domain warping (two levels, Inigo Quilez style) ──
        float t = u_time * 0.06;

        vec2 q = vec2(
          fbm(p + vec2(0.0, 0.0) + t),
          fbm(p + vec2(5.2, 1.3) + t * 0.7)
        );

        // Mouse pushes the warp field
        vec2 mWarp = vec2(mInf * 0.4, mInf * 0.3);

        vec2 r = vec2(
          fbm(p + 4.0 * q + vec2(1.7, 9.2) + t * 0.4 + mWarp),
          fbm(p + 4.0 * q + vec2(8.3, 2.8) + t * 0.25 + mWarp * 1.3)
        );

        float f = fbm(p + 4.0 * r);

        // Normalize
        f = f * 0.5 + 0.5;
        float rn = r.x * 0.5 + 0.5;
        float qn = q.y * 0.5 + 0.5;

        // ── Colour mixing ──
        vec3 color;

        // Dark palette
        vec3 d0 = vec3(0.0);                     // black base
        vec3 d1 = vec3(0.04, 0.06, 0.14);        // deep navy
        vec3 d2 = vec3(0.09, 0.03, 0.13);        // muted purple
        vec3 d3 = vec3(0.02, 0.09, 0.11);        // deep teal
        vec3 d4 = vec3(0.12, 0.10, 0.18);        // warm plum highlight

        vec3 darkCol = mix(d0, d1, smoothstep(0.0, 0.8, f));
        darkCol = mix(darkCol, d2, smoothstep(0.2, 0.9, rn) * 0.7);
        darkCol = mix(darkCol, d3, smoothstep(0.3, 0.85, qn) * 0.5);
        darkCol += d4 * smoothstep(0.5, 1.0, f) * 0.4;
        darkCol += mInf * vec3(0.10, 0.07, 0.18);   // mouse glow

        // Light palette
        vec3 l0 = vec3(1.0);                     // white base
        vec3 l1 = vec3(0.91, 0.93, 0.98);        // cool blue-white
        vec3 l2 = vec3(0.95, 0.91, 0.97);        // soft lavender
        vec3 l3 = vec3(0.91, 0.96, 0.96);        // hint of teal
        vec3 l4 = vec3(0.88, 0.90, 0.96);        // deeper fold

        vec3 lightCol = mix(l0, l1, smoothstep(0.0, 0.8, f) * 0.7);
        lightCol = mix(lightCol, l2, smoothstep(0.2, 0.9, rn) * 0.5);
        lightCol = mix(lightCol, l3, smoothstep(0.3, 0.85, qn) * 0.35);
        lightCol = mix(lightCol, l4, smoothstep(0.5, 1.0, f) * 0.35);
        lightCol -= mInf * vec3(0.06, 0.04, 0.01);  // mouse shadow/focus

        color = mix(lightCol, darkCol, u_dark);

        gl_FragColor = vec4(color, 1.0);
      }
    `;

    // ── WebGL setup ──

    function makeShader(type: number, src: string) {
      const s = gl!.createShader(type)!;
      gl!.shaderSource(s, src);
      gl!.compileShader(s);
      if (!gl!.getShaderParameter(s, gl!.COMPILE_STATUS)) {
        console.error(gl!.getShaderInfoLog(s));
      }
      return s;
    }

    const prog = gl.createProgram()!;
    gl.attachShader(prog, makeShader(gl.VERTEX_SHADER, vertSrc));
    gl.attachShader(prog, makeShader(gl.FRAGMENT_SHADER, fragSrc));
    gl.linkProgram(prog);
    gl.useProgram(prog);

    // Full-screen triangle (covers clip space with a single tri)
    const buf = gl.createBuffer()!;
    gl.bindBuffer(gl.ARRAY_BUFFER, buf);
    gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1,-1, 3,-1, -1,3]), gl.STATIC_DRAW);
    const aPos = gl.getAttribLocation(prog, "a_position");
    gl.enableVertexAttribArray(aPos);
    gl.vertexAttribPointer(aPos, 2, gl.FLOAT, false, 0, 0);

    const uRes   = gl.getUniformLocation(prog, "u_resolution");
    const uTime  = gl.getUniformLocation(prog, "u_time");
    const uMouse = gl.getUniformLocation(prog, "u_mouse");
    const uDark  = gl.getUniformLocation(prog, "u_dark");

    // ── State ──

    let targetMouse = { x: -9999, y: -9999 };
    let smoothMouse = { x: -9999, y: -9999 };
    let darkSmooth = document.documentElement.classList.contains("dark") ? 1.0 : 0.0;
    let animFrame = 0;
    const startTime = performance.now();

    function resize() {
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      const rect = canvas.getBoundingClientRect();
      canvas.width = rect.width * dpr;
      canvas.height = rect.height * dpr;
      gl!.viewport(0, 0, canvas.width, canvas.height);
    }
    resize();

    // ── Render loop ──

    function frame() {
      // Smooth mouse interpolation
      const lerpRate = 0.06;
      if (targetMouse.x < -999) {
        smoothMouse.x += (targetMouse.x - smoothMouse.x) * 0.02;
        smoothMouse.y += (targetMouse.y - smoothMouse.y) * 0.02;
      } else {
        smoothMouse.x += (targetMouse.x - smoothMouse.x) * lerpRate;
        smoothMouse.y += (targetMouse.y - smoothMouse.y) * lerpRate;
      }

      // Smooth theme transition
      const darkTarget = document.documentElement.classList.contains("dark") ? 1.0 : 0.0;
      darkSmooth += (darkTarget - darkSmooth) * 0.04;

      const elapsed = (performance.now() - startTime) / 1000.0;
      const dpr = Math.min(window.devicePixelRatio || 1, 2);

      gl!.uniform2f(uRes, canvas.width, canvas.height);
      gl!.uniform1f(uTime, elapsed);
      gl!.uniform2f(uMouse, smoothMouse.x * dpr, (canvas.height / dpr - smoothMouse.y) * dpr);
      gl!.uniform1f(uDark, darkSmooth);

      gl!.drawArrays(gl!.TRIANGLES, 0, 3);
      animFrame = requestAnimationFrame(frame);
    }
    frame();

    // ── Events ──

    const footerEl = canvas.parentElement!;
    footerEl.addEventListener("mousemove", (e: MouseEvent) => {
      const rect = canvas.getBoundingClientRect();
      targetMouse.x = e.clientX - rect.left;
      targetMouse.y = e.clientY - rect.top;
    });

    footerEl.addEventListener("mouseleave", () => {
      targetMouse.x = -9999;
      targetMouse.y = -9999;
    });

    let resizeTimer: ReturnType<typeof setTimeout>;
    window.addEventListener("resize", () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(resize, 100);
    });

    document.addEventListener("astro:before-swap", () => {
      cancelAnimationFrame(animFrame);
    }, { once: true });
  });
</script>
