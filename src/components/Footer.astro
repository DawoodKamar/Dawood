---
import NewsletterSignup from "./NewsletterSignup.astro";
const isHome = Astro.url.pathname === "/";
---

{!isHome && <div class="mx-auto max-w-4xl px-4 pt-8"><NewsletterSignup compact /></div>}
<footer class="border-t border-gray-200 dark:border-gray-800">
  <div class="mx-auto flex max-w-4xl flex-col items-center gap-4 px-4 py-8 md:flex-row md:justify-between">
    <p class="text-sm text-gray-500 dark:text-gray-400">
      &copy; {new Date().getFullYear()} Dawood Kamar. All rights reserved.
    </p>

    <nav class="flex gap-4 text-sm">
      <a href="/" class="hover:text-blue-600 dark:hover:text-blue-400">Home</a>
      <a href="/blog/" class="hover:text-blue-600 dark:hover:text-blue-400">Blog</a>
      <a href="/contact/" class="hover:text-blue-600 dark:hover:text-blue-400">Contact</a>
    </nav>

    <div class="flex gap-4">
      <a
        href="https://youtube.com/@dawoodkamar"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="YouTube"
        class="text-sm text-gray-500 hover:text-blue-600 dark:text-gray-400 dark:hover:text-blue-400"
      >YouTube</a>
      <a
        href="https://linkedin.com/in/dawood-kamar"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
        class="text-sm text-gray-500 hover:text-blue-600 dark:text-gray-400 dark:hover:text-blue-400"
      >LinkedIn</a>
    </div>
  </div>
</footer>
